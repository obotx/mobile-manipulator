<?xml version="1.0"?>
<robot name="summit_xl_arm" xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- ================= ARGUMENTS ================= -->
  <xacro:arg name="prefix" default="summit_"/>  <!-- ✅ Non-empty prevents collisions -->
  <xacro:arg name="use_gazebo" default="true"/>
  <xacro:arg name="hq" default="true"/>
  <xacro:arg name="arm_mount_x" default="0.0"/>
  <xacro:arg name="arm_mount_y" default="0.0"/>
  <xacro:arg name="arm_mount_z" default="0.38062"/>
  <xacro:arg name="arm_mount_r" default="0.0"/>
  <xacro:arg name="arm_mount_p" default="0.0"/>
  <xacro:arg name="arm_mount_yaw" default="0.0"/>

  <!-- ================= CORRECTED IMPORTS (Your Paths) ================= -->
  <xacro:include filename="$(find summit_xl_description)/robots/summit_xls.urdf.xacro"/>
  <xacro:include filename="$(find mm_description)/urdf/arm/arm.urdf.xacro"/>

  <!-- ================= 1. MOBILE BASE ================= -->
  <!-- Macro name from summit_xls.urdf.xacro: "summit_xl" -->
  <xacro:summit_xl prefix="$(arg prefix)" publish_bf="true" hq="$(arg hq)"/>

  <!-- ================= 2. MOUNT JOINT ================= -->
  <!-- Connects base to arm (both prefixed) -->
  <joint name="$(arg prefix)arm_mount_joint" type="fixed">
    <parent link="$(arg prefix)base_link_platform"/>
    <child link="$(arg prefix)arm_root_link"/>  <!-- Arm's root link (prefixed) -->
    <origin xyz="$(arg arm_mount_x) $(arg arm_mount_y) $(arg arm_mount_z)" 
            rpy="$(arg arm_mount_r) $(arg arm_mount_p) $(arg arm_mount_yaw)"/>
  </joint>

  <!-- ================= 3. ARM ================= -->
  <xacro:arm prefix="$(arg prefix)" use_gazebo="$(arg use_gazebo)"/>

  <!-- ================= 4. MERGED ROS2_CONTROL (SINGLE BLOCK) ================= -->
  <xacro:if value="$(arg use_gazebo)">
    
    <!-- Gazebo plugin -->
    <gazebo>
      <plugin filename="gz_ros2_control-system" 
              name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find mm_control)/config/summit_xl_arm_controllers.yaml</parameters>
      </plugin>
    </gazebo>

    <!-- Combined hardware definition (base + arm joints) -->
    <ros2_control name="GazeboSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <!-- ===== MOBILE BASE WHEELS (from summit_xls.urdf.xacro) ===== -->
      <joint name="$(arg prefix)front_left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="$(arg prefix)front_right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="$(arg prefix)back_left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="$(arg prefix)back_right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- ===== ARM JOINTS (from arm.urdf.xacro) ===== -->
      <joint name="$(arg prefix)joint_slider_left_slide">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="$(arg prefix)joint_slider_left_hinge">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="$(arg prefix)joint_telescopic_slide">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="$(arg prefix)joint_hinge_telescopic_hand">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="$(arg prefix)joint_slider_right_slide">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- ===== DG4F GRIPPER JOINTS (Prefixed) ===== -->
        <joint name="$(arg prefix)j_dg_1_1">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_1_2">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_1_3">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_1_4">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <!-- Finger 2 joints -->
        <joint name="$(arg prefix)j_dg_2_1">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_2_2">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_2_3">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_2_4">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <!-- Finger 3 joints -->
        <joint name="$(arg prefix)j_dg_3_1">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_3_2">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_3_3">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)j_dg_3_4">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name = "$(arg prefix)j_dg_4_1">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name = "$(arg prefix)j_dg_4_2">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name = "$(arg prefix)j_dg_4_3">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name = "$(arg prefix)j_dg_4_4">
            <command_interface name="position">
                <param name="min_position">-0.5</param>
                <param name="max_position">0.5</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        

        <joint name = "$(arg prefix)j_dg_1_inner">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>    

        <!-- <joint name = "$(arg prefix)j_dg_1_outer">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <param name="mimic">$(arg prefix)j_dg_1_inner</param>
            <param name="multiplier">1.179</param>
            <param name="offset">0.0</param>
        </joint> -->

        <!-- <joint name = "$(arg prefix)j_dg_1_mimic">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <param name="mimic">$(arg prefix)j_dg_1_inner</param>
            <param name="multiplier">0.2514</param>
            <param name="offset">0.0</param>
        </joint> -->

        <joint name = "$(arg prefix)j_dg_4_inner">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        
        </joint>

        <!-- <joint name = "$(arg prefix)j_dg_4_outer">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <param name="mimic">$(arg prefix)j_dg_4_inner</param>
            <param name="multiplier">1.179</param>
            <param name="offset">0.0</param>
        </joint> -->

        <!-- <joint name = "$(arg prefix)j_dg_4_mimic">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <param name="mimic">$(arg prefix)j_dg_4_inner</param>
            <param name="multiplier">0.2514</param>
            <param name="offset">0.0</param>
        </joint> -->
    </ros2_control>
  </xacro:if>

</robot>