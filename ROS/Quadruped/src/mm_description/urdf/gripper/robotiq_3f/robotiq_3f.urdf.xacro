<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="robotiq_3f_gripper">
  
  <xacro:macro name="robotiq_3f" params="prefix use_gazebo">
    
    <xacro:property name="gripper_mesh_prefix" value="file://$(find mm_description)/meshes/gripper/robotiq_3f"/>
    <xacro:property name="scale_factor" value="0.7"/>
    
    <xacro:include filename="$(find mm_description)/urdf/gripper/robotiq_3f/robotiq_3f_finger.xacro" />
    <xacro:robotiq_3f_finger prefix="${prefix}finger_1_" scale_factor="${scale_factor}" use_gazebo="${use_gazebo}"/>
    <xacro:robotiq_3f_finger prefix="${prefix}finger_2_" scale_factor="${scale_factor}" use_gazebo="${use_gazebo}"/>
    <xacro:robotiq_3f_finger prefix="${prefix}finger_middle_" scale_factor="${scale_factor}" use_gazebo="${use_gazebo}"/>
      
    <!-- link list -->
    <link name="${prefix}base_link_palm"/>
    
    <joint name="${prefix}base_to_palm" type="fixed">
      <parent link="${prefix}base_link_palm"/>
      <child link="${prefix}palm"/>
      <origin xyz="${-0.041275 * scale_factor} 0 0" rpy="0 0 1.5708"/>
    </joint>

    <link name="${prefix}palm">
      <visual>
        <geometry>
          <mesh filename="${gripper_mesh_prefix}/visual/palm.dae" scale="${scale_factor} ${scale_factor} ${scale_factor}" />
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="${gripper_mesh_prefix}/collision/palm.STL" scale="${scale_factor} ${scale_factor} ${scale_factor}" />
        </geometry>
      </collision>
      <inertial>
        <origin xyz="${-0.043906 * scale_factor} ${-0.001342 * scale_factor} 0" rpy="0.000000 0.000000 1.570800"/>
        <mass value="1.300000"/>
        <inertia ixx="2.853974e-03" ixy="0" ixz="0" iyy="2.370279e-03" iyz="0" izz="2.284843e-03" />
      </inertial>
    </link>
    
    <link name="${prefix}tool0"/>
    <!-- end of link list -->
    
    <!-- joint list -->
    <joint name="${prefix}palm_finger_1_joint" type="revolute">
      <parent link="${prefix}palm"/>
      <child link="${prefix}finger_1_link_0"/>
      <axis xyz="0 1 0"/>
      <origin xyz="${-0.0455 * scale_factor} ${0.0214 * scale_factor} ${0.036 * scale_factor}" rpy="0 3.1416 -1.57"/>
      <limit lower="-0.1784" upper="0.192" effort="100" velocity="100"/>
    </joint>
    
    <joint name="${prefix}palm_finger_2_joint" type="revolute">
      <parent link="${prefix}palm"/>
      <child link="${prefix}finger_2_link_0"/>
      <axis xyz="0 1 0"/>
      <origin xyz="${-0.0455 * scale_factor} ${0.0214 * scale_factor} ${-0.036 * scale_factor}" rpy="0 3.1416 -1.57"/>
      <limit lower="-0.192" upper="0.1784" effort="100" velocity="100"/>
    </joint>
    
    <joint name="${prefix}palm_finger_middle_joint" type="fixed">
      <parent link="${prefix}palm"/>
      <child link="${prefix}finger_middle_link_0"/>
      <origin xyz="${0.0455 * scale_factor} ${0.0214 * scale_factor} 0" rpy="0 0 1.57"/>
    </joint>
    
    <joint name="${prefix}palm_tool0" type="fixed">
      <parent link="${prefix}palm"/>
      <child link="${prefix}tool0"/>
      <origin xyz="0.0 ${0.1 * scale_factor} 0.0" rpy="0 0 1.5707"/>
    </joint>
    <!-- end of joint list -->

    <!-- ==================== Gazebo Harmonic ros2_control ==================== -->
    <xacro:if value="${use_gazebo}">
      <ros2_control name="${prefix}GripperGazeboSystem" type="system">
        <hardware>
          <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        <joint name="${prefix}palm_finger_1_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="${prefix}palm_finger_2_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
      </ros2_control>
    </xacro:if>
  </xacro:macro>
</robot>