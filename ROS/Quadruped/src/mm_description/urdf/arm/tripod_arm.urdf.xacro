<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" xmlns:nl="http://ros.org/nonlinear_mimic">

  <xacro:macro name="tripod_arm" params="prefix use_gazebo">

    <!-- ================= XACRO PROPERTIES ================= -->
    <xacro:property name="vertical_mesh_prefix" value="file://$(find mm_description)/meshes/arm/vertical_arm/tripod"/>
    <xacro:property name="telescopic_mesh_prefix" value="file://$(find mm_description)/meshes/arm/telescopic_arm/tripod"/>
    
    <xacro:include filename="$(find dg_description)/urdf/dg4f.urdf.xacro" />
    <xacro:dg4f prefix="${prefix}" use_gazebo="${use_gazebo}"/>

    <xacro:property name="slide_limit_min" value="-1"/>
    <xacro:property name="slide_limit_max" value="1.112"/>
    <xacro:property name="hinge_limit_min" value="-3.14159"/>
    <xacro:property name="hinge_limit_max" value="3.14159"/>
    <xacro:property name="telescopic_limit_min" value="-1"/>
    <xacro:property name="telescopic_limit_max" value="0.45"/>
    <xacro:property name="telescopic_hinge_limit_min" value="-0.7"/>
    <xacro:property name="telescopic_hinge_limit_max" value="0.7"/>
    
    <xacro:property name="default_effort" value="1000"/>
    <xacro:property name="default_velocity" value="50"/>
    <xacro:property name="slide_damping" value="1"/>

    <!-- ================= ARM ROOT LINK ================= -->
    <link name="${prefix}arm_root_link">
      <inertial>
        <mass value="5.0"/>
        <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.05"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
      </inertial>
      <visual>
        <geometry><mesh filename="${vertical_mesh_prefix}/frame.obj"/></geometry>
      </visual> 
    </link>

    <!-- ================= LEFT SLIDER ================= -->
    <link name="${prefix}slider_left_prismatic_frame">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>
    <joint name="${prefix}joint_slider_left_slide" type="prismatic">
      <parent link="${prefix}arm_root_link"/>
      <child link="${prefix}slider_left_prismatic_frame"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${slide_limit_min}" upper="${slide_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="1.0" friction="0.0"/>
    </joint>

    <link name="${prefix}slider_left_hinge_frame">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>
    <joint name="${prefix}joint_slider_left_hinge" type="revolute">
      <parent link="${prefix}slider_left_prismatic_frame"/>
      <child link="${prefix}slider_left_hinge_frame"/>
      <origin xyz="-0.082983 -0.025336 0.15148" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="1.0" friction="0.0"/>
    </joint>

    <link name="${prefix}slider_left">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/slider_left.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_slider_left_vis" type="fixed">
      <parent link="${prefix}slider_left_hinge_frame"/>
      <child link="${prefix}slider_left"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- ================= TELESCOPIC ARM ================= -->
    <link name="${prefix}telescopic_arm">
      <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/motor.obj"/></geometry></visual>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/horizontal_link.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_telescopic_slide" type="prismatic">
      <parent link="${prefix}slider_left"/>
      <child link="${prefix}telescopic_arm"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="-1 0 0"/>
      <limit lower="${telescopic_limit_min}" upper="${telescopic_limit_max}" effort="10000000" velocity="1000000"/>
      <dynamics damping="0.1" friction="0.01"/>
    </joint>

    <link name="${prefix}telescopic_hand">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/hinge_finger.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_telescopic_hand" type="fixed">
      <parent link="${prefix}telescopic_arm"/>
      <child link="${prefix}telescopic_hand"/>
      <origin xyz="-0.032051 0.025225 0" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}hinge_telescopic_hand">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/finger_bracket.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_hinge_telescopic_hand" type="revolute">
      <parent link="${prefix}telescopic_hand"/>
      <child link="${prefix}hinge_telescopic_hand"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="1.0" friction="0.0"/>
    </joint>

    <link name="${prefix}base_hand"/>
    <joint name="${prefix}base_hand_to_hand" type="fixed">
      <parent link="${prefix}base_hand"/>
      <child link="${prefix}l_dg_mount"/>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
    </joint>

    <joint name="${prefix}telescopic_to_hand" type="fixed">
      <parent link="${prefix}hinge_telescopic_hand"/>
      <child link="${prefix}base_hand"/>
      <origin xyz="-0.045853 0 0" rpy="0 -1.5708 0"/>
    </joint>

    <!-- ================= RIGHT SLIDER ================= -->
    <link name="${prefix}slider_right_slide_frame">
      <inertial><mass value="0.5"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>
    <joint name="${prefix}joint_slider_right_slide" type="prismatic">
      <parent link="${prefix}arm_root_link"/>
      <child link="${prefix}slider_right_slide_frame"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${slide_limit_min}" upper="${slide_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="1.0" friction="0.0"/>
    </joint>

    <link name="${prefix}slider_right_hinge_frame">
      <inertial><mass value="0.3"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>
    <joint name="${prefix}joint_slider_right_hinge" type="revolute">
      <parent link="${prefix}slider_right_slide_frame"/>
      <child link="${prefix}slider_right_hinge_frame"/>
      <origin xyz="0.082983 0.025336 0.15148" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <mimic joint="${prefix}joint_slider_left_hinge" multiplier="1.0" offset="0.0"/>
      <dynamics damping="1.0" friction="0.0"/>
    </joint>

    <link name="${prefix}slider_right_mesh">
      <inertial><mass value="0.2"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/slider_right.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_slider_right_vis_offset" type="fixed">
      <parent link="${prefix}slider_right_hinge_frame"/>
      <child link="${prefix}slider_right_mesh"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <xacro:if value="${use_gazebo}">
      <gazebo>
        <plugin filename="libNonLinearMimic.so" name="NonLinearMimic">
            <joint>${prefix}joint_slider_right_slide</joint>
            <n_mimic>2</n_mimic>
            <mimicJoint1>${prefix}joint_slider_left_slide</mimicJoint1>
            <mimicJoint2>${prefix}joint_slider_left_hinge</mimicJoint2>
            <eq>{mimicJoint1}-0.165966*tan({mimicJoint2})</eq>
            <kp>800</kp>
            <kd>50</kd>
            <ki>8</ki>
            <max_torque>1000</max_torque>
            <debug>false</debug>
        </plugin>
      </gazebo>
      
      <ros2_control name="${prefix}ArmGazeboSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name="${prefix}joint_slider_left_slide">
            <command_interface name="position">
                <param name="min">${slide_limit_min}</param>
                <param name="max">${slide_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${slide_limit_min}</param>
                <param name="max">${slide_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_slider_left_hinge">
            <command_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_telescopic_slide">
            <command_interface name="position">
                <param name="min">${telescopic_limit_min}</param>
                <param name="max">${telescopic_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${telescopic_limit_min}</param>
                <param name="max">${telescopic_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_hinge_telescopic_hand">
            <command_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="${prefix}joint_slider_right_slide">
            <state_interface name="position">
                <param name="min">${slide_limit_min}</param>
                <param name="max">${slide_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_slider_right_hinge" mimic="true">
            <state_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
      </ros2_control>
    </xacro:if>
  </xacro:macro>
</robot>