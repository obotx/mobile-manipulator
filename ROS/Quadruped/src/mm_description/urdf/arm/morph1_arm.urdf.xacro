<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" xmlns:nl="http://ros.org/nonlinear_mimic">

  <xacro:macro name="morph1_arm" params="prefix use_gazebo">

    <!-- ================= XACRO PROPERTIES ================= -->
    <xacro:property name="vertical_mesh_prefix" value="file://$(find mm_description)/meshes/arm/vertical_arm/morph_1"/>
    <xacro:property name="telescopic_mesh_prefix" value="file://$(find mm_description)/meshes/arm/telescopic_arm/morph_1"/>
    
    <xacro:include filename="$(find mm_description)/urdf/gripper/robotiq_3f.urdf.xacro" />
    <xacro:robotiq_3f prefix="${prefix}" use_gazebo="${use_gazebo}"/>

    <xacro:property name="slide_limit_min" value="-1"/>
    <xacro:property name="slide_limit_max" value="1.112"/>
    <xacro:property name="hinge_limit_min" value="-3.14159"/>
    <xacro:property name="hinge_limit_max" value="3.14159"/>
    <xacro:property name="telescopic_limit_min" value="-1"/>
    <xacro:property name="telescopic_limit_max" value="0.5"/>
    <xacro:property name="telescopic_hinge_limit_min" value="-1.1345"/>
    <xacro:property name="telescopic_hinge_limit_max" value="1.1345"/>
    <xacro:property name="gripper_roll_limit_min" value="-0.7"/>
    <xacro:property name="gripper_roll_limit_max" value="0.7"/>
    <xacro:property name="gripper_pitch_limit_min" value="-0.7"/>
    <xacro:property name="gripper_pitch_limit_max" value="0.7"/>
    <xacro:property name="gripper_yaw_limit_min" value="-0.7"/>
    <xacro:property name="gripper_yaw_limit_max" value="0.7"/>
    
    <xacro:property name="default_effort" value="1000"/>
    <xacro:property name="default_velocity" value="50"/>
    <xacro:property name="slide_damping" value="1"/>

    <!-- ================= ARM ROOT LINK ================= -->
    <link name="${prefix}arm_root_link">
      <inertial>
        <mass value="5.0"/>
        <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
      </inertial>
      <visual><geometry><mesh filename="${vertical_mesh_prefix}/vertical_frame.obj"/></geometry></visual> 
      <collision><geometry><mesh filename="${vertical_mesh_prefix}/vertical_frame_collision.stl"/></geometry></collision>
    </link>

    <!-- ================= LEFT SLIDER ================= -->
    <link name="${prefix}slider_left_prismatic_frame">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>
    <joint name="${prefix}joint_slider_left_slide" type="prismatic">
      <parent link="${prefix}arm_root_link"/>
      <child link="${prefix}slider_left_prismatic_frame"/>
      <origin xyz="-0.05 -0.034285 0.069379" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${slide_limit_min}" upper="${slide_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <link name="${prefix}slider_left_hinge_frame">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/left_rotation.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_slider_left_hinge" type="revolute">
      <parent link="${prefix}slider_left_prismatic_frame"/>
      <child link="${prefix}slider_left_hinge_frame"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <link name="${prefix}slider_left">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${vertical_mesh_prefix}/left_slider.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_slider_left_vis" type="fixed">
      <parent link="${prefix}slider_left_hinge_frame"/>
      <child link="${prefix}slider_left"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- ================= TELESCOPIC ARM ================= -->
    <link name="${prefix}telescopic_arm">
      <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/telescopic.obj"/></geometry></visual>
      <collision><geometry><mesh filename="${telescopic_mesh_prefix}/telescopic_collision.stl"/></geometry></collision>
    </link>
    <joint name="${prefix}joint_telescopic_slide" type="prismatic">
      <parent link="${prefix}slider_left"/>
      <child link="${prefix}telescopic_arm"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="-1 0 0"/>
      <limit lower="${telescopic_limit_min}" upper="${telescopic_limit_max}" effort="10000000" velocity="1000000"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <link name="${prefix}hinge_telescopic_hand">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/hand_bracket.obj"/></geometry></visual>
      <collision><geometry><mesh filename="${telescopic_mesh_prefix}/hand_bracket_collision.stl"/></geometry></collision>
    </link>
    <joint name="${prefix}joint_hinge_telescopic_hand" type="revolute">
      <parent link="${prefix}telescopic_arm"/>
      <child link="${prefix}hinge_telescopic_hand"/>
      <origin xyz="-0.050611 0.038098 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <!-- ==================== Palm ==================== -->
    <link name="${prefix}palm_wrist_roll">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>

    <!-- Pitch link (spacer) -->
    <link name="${prefix}palm_wrist_pitch">
      <inertial><mass value="0.1"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>

    <!-- Roll joint (rotation around X-axis) -->
    <joint name="${prefix}palm_wrist_roll_joint" type="revolute">
      <parent link="${prefix}hinge_telescopic_hand"/>
      <child link="${prefix}palm_wrist_roll"/>
      <origin xyz="-0.107377 0 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="${gripper_roll_limit_min}" upper="${gripper_roll_limit_max}" 
            effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <!-- Pitch joint (rotation around Y-axis) -->
    <joint name="${prefix}palm_wrist_pitch_joint" type="revolute">
      <parent link="${prefix}palm_wrist_roll"/>
      <child link="${prefix}palm_wrist_pitch"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${gripper_pitch_limit_min}" upper="${gripper_pitch_limit_max}" 
            effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <!-- Yaw joint (rotation around Z-axis) -->
    <joint name="${prefix}palm_wrist_yaw_joint" type="revolute">
      <parent link="${prefix}palm_wrist_pitch"/>
      <child link="${prefix}base_link_palm"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${gripper_yaw_limit_min}" upper="${gripper_yaw_limit_max}" 
            effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <!-- ================= RIGHT SLIDER ================= -->
    <link name="${prefix}slider_right_slide_frame">
      <inertial><mass value="0.5"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${vertical_mesh_prefix}/right_slider.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_slider_right_slide" type="prismatic">
      <parent link="${prefix}arm_root_link"/>
      <child link="${prefix}slider_right_slide_frame"/>
      <origin xyz="0.05 0.0325 0.069379" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${slide_limit_min}" upper="${slide_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <link name="${prefix}slider_right_hinge_frame">
      <inertial><mass value="0.3"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
    </link>
    <joint name="${prefix}joint_slider_right_hinge" type="revolute">
      <parent link="${prefix}slider_right_slide_frame"/>
      <child link="${prefix}slider_right_hinge_frame"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
      <mimic joint="${prefix}joint_slider_left_hinge" multiplier="1.0" offset="0.0"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <link name="${prefix}slider_right_mesh">
      <inertial><mass value="0.2"/><inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/><origin xyz="0 0 0" rpy="0 0 0"/></inertial>
      <visual><geometry><mesh filename="${telescopic_mesh_prefix}/right_rotation.obj"/></geometry></visual>
    </link>
    <joint name="${prefix}joint_slider_right_vis_offset" type="fixed">
      <parent link="${prefix}slider_right_hinge_frame"/>
      <child link="${prefix}slider_right_mesh"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <xacro:if value="${use_gazebo}">
      <gazebo>
        <plugin filename="libNonLinearMimic.so" name="NonLinearMimic">
            <joint>${prefix}joint_slider_right_slide</joint>
            <n_mimic>2</n_mimic>
            <mimicJoint1>${prefix}joint_slider_left_slide</mimicJoint1>
            <mimicJoint2>${prefix}joint_slider_left_hinge</mimicJoint2>
            <eq>{mimicJoint1}-0.165966*tan({mimicJoint2})</eq>
            <kp>200</kp>
            <kd>50</kd>
            <ki>3</ki>
            <max_torque>1000</max_torque>
            <debug>false</debug>
        </plugin>
      </gazebo>
      
      <ros2_control name="${prefix}ArmGazeboSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <joint name="${prefix}joint_slider_left_slide">
            <command_interface name="position">
                <param name="min">${slide_limit_min}</param>
                <param name="max">${slide_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${slide_limit_min}</param>
                <param name="max">${slide_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_slider_left_hinge">
            <command_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_telescopic_slide">
            <command_interface name="position">
                <param name="min">${telescopic_limit_min}</param>
                <param name="max">${telescopic_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${telescopic_limit_min}</param>
                <param name="max">${telescopic_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_hinge_telescopic_hand">
            <command_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="${prefix}joint_slider_right_slide">
            <state_interface name="position">
                <param name="min">${slide_limit_min}</param>
                <param name="max">${slide_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        
        <joint name="${prefix}joint_slider_right_hinge" mimic="true">
            <state_interface name="position">
                <param name="min">${hinge_limit_min}</param>
                <param name="max">${hinge_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="${prefix}palm_wrist_roll_joint">
            <command_interface name="position">
                <param name="min">${gripper_roll_limit_min}</param>
                <param name="max">${gripper_roll_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${gripper_roll_limit_min}</param>
                <param name="max">${gripper_roll_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="${prefix}palm_wrist_pitch_joint">
            <command_interface name="position">
                <param name="min">${gripper_pitch_limit_min}</param>
                <param name="max">${gripper_pitch_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${gripper_pitch_limit_min}</param>
                <param name="max">${gripper_pitch_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="${prefix}palm_wrist_yaw_joint">
            <command_interface name="position">
                <param name="min">${gripper_yaw_limit_min}</param>
                <param name="max">${gripper_yaw_limit_max}</param>
            </command_interface>
            <state_interface name="position">
                <param name="min">${gripper_yaw_limit_min}</param>
                <param name="max">${gripper_yaw_limit_max}</param>
            </state_interface>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
      </ros2_control>
    </xacro:if>
  </xacro:macro>
</robot>