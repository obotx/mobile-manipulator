<?xml version="1.0" ?>
<robot name="arm_parts" xmlns:xacro="http://www.ros.org/wiki/xacro" xmlns:nl="http://ros.org/nonlinear_mimic">

  <!-- ================= XACRO PROPERTIES ================= -->
  <!-- Mesh path prefix (override at launch if needed) -->
  <xacro:property name="vertical_mesh_prefix" value="file://$(find mm_description)/meshes/arm/vertical_arm"/>
  <xacro:property name="telescopic_mesh_prefix" value="file://$(find mm_description)/meshes/arm/telescopic_arm"/>
  <xacro:include filename="$(find dg_description)/urdf/dg4f.urdf" />

  <!-- Joint limits (easy to tune) -->
  <xacro:property name="slide_limit_min" value="0"/>
  <xacro:property name="slide_limit_max" value="1.112"/>
  <xacro:property name="hinge_limit_min" value="-3.14159"/>
  <xacro:property name="hinge_limit_max" value="3.14159"/>
  <xacro:property name="telescopic_limit_min" value="0"/>
  <xacro:property name="telescopic_limit_max" value="0.457"/>
  <xacro:property name="telescopic_hinge_limit_min" value="-0.7"/>
  <xacro:property name="telescopic_hinge_limit_max" value="0.7"/>
  
  <!-- Dynamics -->
  <xacro:property name="default_effort" value="1000"/>
  <xacro:property name="default_velocity" value="5"/>
  <xacro:property name="slide_damping" value="500"/>
  
  <!-- Non-linear mimic params -->
  <xacro:property name="nl_coeff" value="0.165966"/>
  <xacro:property name="nl_hinge_clamp_min" value="-1.4"/>
  <xacro:property name="nl_hinge_clamp_max" value="1.4"/>

  <!-- ================= BASE LINK (FOOTPRINT) ================= -->
  <!-- Root link - just a footprint, very small mass -->
  <link name="base_link"/>

  <joint name="arm_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================= ARM ================= -->
  <link name="arm">
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.05"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="${vertical_mesh_prefix}/frame.obj"/></geometry>
    </visual> 
    <!-- <visual>
      <geometry><mesh filename="${vertical_mesh_prefix}/vertical_bracket.stl"/></geometry>
    </visual>
    <visual>
      <geometry><mesh filename="${vertical_mesh_prefix}/vertical_link.stl"/></geometry>
    </visual>
    <visual>
      <geometry><mesh filename="${vertical_mesh_prefix}/arm_att.stl"/></geometry>
    </visual>
    <visual>
      <geometry><mesh filename="${vertical_mesh_prefix}/rotate_base.stl"/></geometry>
    </visual>
    <visual>
      <geometry><mesh filename="${vertical_mesh_prefix}/bolts.stl"/></geometry>
    </visual> -->
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/> 
      <geometry>
        <cylinder length="0.04" radius="0.160372"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= LEFT SLIDER ================= -->
  <link name="slider_left_prismatic_frame">
    <inertial>
      <mass value="0.0001"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>
  <joint name="joint_slider_left_slide" type="prismatic">
    <parent link="arm"/>
    <child link="slider_left_prismatic_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${slide_limit_min}" upper="${slide_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
  </joint>

  <link name="slider_left_hinge_frame">
    <inertial>
      <mass value="0.0001"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>
  <joint name="joint_slider_left_hinge" type="revolute">
    <parent link="slider_left_prismatic_frame"/>
    <child link="slider_left_hinge_frame"/>
    <origin xyz="-0.082983 -0.025336 0.15148" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
  </joint>

  <link name="slider_left">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="${telescopic_mesh_prefix}/slider_left.obj"/></geometry>
    </visual>
  </link>
  <joint name="joint_slider_left_vis" type="fixed">
    <parent link="slider_left_hinge_frame"/>
    <child link="slider_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================= TELESCOPIC ARM ================= -->
  <link name="telescopic_arm">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
    <visual><geometry><mesh filename="${telescopic_mesh_prefix}/motor.obj"/></geometry></visual>
    <visual><geometry><mesh filename="${telescopic_mesh_prefix}/horizontal_link.obj"/></geometry></visual>
  </link>
  <joint name="joint_telescopic_slide" type="prismatic">
    <parent link="slider_left"/>
    <child link="telescopic_arm"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="${telescopic_limit_min}" upper="${telescopic_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
  </joint>

  <link name="telescopic_hand">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="${telescopic_mesh_prefix}/hinge_finger.obj"/></geometry>
    </visual>
  </link>
  <joint name="joint_telescopic_hand" type="fixed">
    <parent link="telescopic_arm"/>
    <child link="telescopic_hand"/>
    <origin xyz="-0.032051 0.025225 0" rpy="0 0 0"/>
  </joint>


  <link name="hinge_telescopic_hand">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="${telescopic_mesh_prefix}/finger_bracket.obj"/></geometry>
    </visual>
  </link>
  <joint name="joint_hinge_telescopic_hand" type="revolute">
    <parent link="telescopic_hand"/>
    <child link="hinge_telescopic_hand"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
  </joint>

  <link name="base_hand"/>
  <joint name="base_hand_to_hand" type="fixed">
    <parent link="base_hand"/>
    <child link="l_dg_mount"/>
    <origin xyz="0 0 0" rpy="0 0 1.5708"/>
  </joint>

  <joint name="telescopic_to_hand" type="fixed">
    <parent link="hinge_telescopic_hand"/>
    <child link="base_hand"/>
    <origin xyz="-0.045853 0 0" rpy="0 -1.5708 0"/>
  </joint>

  <!-- ================= RIGHT SLIDER ================= -->
  <link name="slider_right_slide_frame">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>
  <joint name="joint_slider_right_slide" type="prismatic">
    <parent link="arm"/>
    <child link="slider_right_slide_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${slide_limit_min}" upper="${slide_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
    <!-- <mimic joint="joint_slider_left_slide" multiplier="0" offset="0"/> -->
  </joint>

  <gazebo reference="joint_slider_right_slide">
    <kp>50000.0</kp> 
    <kd>1000.0</kd> 
    <maxForce>50000.0</maxForce>
  </gazebo>

  <!-- <nl:mimic target="joint_slider_right_slide">
    <nl:formula>left_slide - ${nl_coeff} * tan(left_hinge)</nl:formula>
    <nl:inputs>
      <nl:input name="left_slide" joint="joint_slider_left_slide"/>
      <nl:input name="left_hinge" joint="joint_slider_left_hinge"/>
    </nl:inputs>
    <nl:limits min="0.0" max="${slide_limit_max}"/>
    <nl:safety>
      <nl:clamp joint="joint_slider_left_hinge" min="${nl_hinge_clamp_min}" max="${nl_hinge_clamp_max}"/>
    </nl:safety>
  </nl:mimic> -->

  <link name="slider_right_hinge_frame">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>
  <joint name="joint_slider_right_hinge" type="revolute">
    <parent link="slider_right_slide_frame"/>
    <child link="slider_right_hinge_frame"/>
    <origin xyz="0.082983 0.025336 0.15148" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${hinge_limit_min}" upper="${hinge_limit_max}" effort="${default_effort}" velocity="${default_velocity}"/>
    <mimic joint="joint_slider_left_hinge" multiplier="1.0" offset="0.0"/>
  </joint>

  <link name="slider_right_mesh">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="${telescopic_mesh_prefix}/slider_right.obj"/></geometry>
    </visual>
  </link>
  <joint name="joint_slider_right_vis_offset" type="fixed">
    <parent link="slider_right_hinge_frame"/>
    <child link="slider_right_mesh"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================= GAZEBO & ROS2_CONTROL (Conditional) ================= -->
  <xacro:arg name="use_gazebo" default="false"/>
  <xacro:if value="$(arg use_gazebo)">
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find mm_control)/config/arm_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
      <joint name="joint_slider_left_slide">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="joint_slider_left_hinge">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="joint_telescopic_slide">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="joint_hinge_telescopic_hand">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="joint_slider_right_slide">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      
      <!-- <joint name="joint_slider_right_hinge">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint> -->

        <joint name="j_dg_1_1">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_1_2">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_1_3">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_1_4">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <!-- ========================================== -->
        <!-- FINGER 2 ACTIVE JOINTS (Commandable)       -->
        <!-- ========================================== -->

        <joint name="j_dg_2_1">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_2_2">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_2_3">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_2_4">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <!-- ========================================== -->
        <!-- FINGER 3 ACTIVE JOINTS (Commandable)       -->
        <!-- ========================================== -->

        <joint name="j_dg_3_1">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_3_2">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_3_3">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_3_4">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <!-- ========================================== -->
        <!-- FINGER 4 ACTIVE JOINTS (Commandable)       -->
        <!-- ========================================== -->

        <joint name="j_dg_4_1">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_4_2">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_4_3">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="j_dg_4_4">
            <command_interface name="position">
                <param name="min_position">-1.5708</param>
                <param name="max_position">1.5708</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <!-- ========================================== -->
        <!-- BASE / MIMIC JOINTS                        -->
        <!-- ========================================== -->

        <!-- j_dg_1_inner is ACTIVE (Master for mimic) -->
        <joint name="j_dg_1_inner">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.01</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>    

        <!-- j_dg_1_outer is MIMIC (Slave). NO command interface allowed. -->
        <joint name="j_dg_1_outer">
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <!-- j_dg_1_mimic is MIMIC (Slave). NO command interface allowed. -->
        <joint name="j_dg_1_mimic">
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <!-- j_dg_4_inner is ACTIVE (Master for mimic) -->
        <joint name="j_dg_4_inner">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <!-- j_dg_4_outer is MIMIC (Slave). NO command interface allowed. -->
        <joint name="j_dg_4_outer">
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <!-- j_dg_4_mimic is MIMIC (Slave). NO command interface allowed. -->
        <joint name="j_dg_4_mimic">
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

    </ros2_control>
  </xacro:if>

</robot>
