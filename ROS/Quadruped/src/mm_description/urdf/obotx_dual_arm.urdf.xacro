<?xml version="1.0"?>
<robot name="summit_xl_dual_arm" xmlns:xacro="http://wiki.ros.org/xacro" xmlns:gz="http://gazebosim.org/schema">

    <!-- ================= ARGUMENTS ================= -->
    <xacro:arg name="prefix" default="summit_"/>
    <xacro:arg name="use_gazebo" default="true"/>
    <xacro:arg name="hq" default="true"/>
  
    <!-- Left Arm Mount -->
    <xacro:arg name="left_arm_mount_x" default="0.12"/>
    <xacro:arg name="left_arm_mount_y" default="0.25"/>
    <xacro:arg name="left_arm_mount_z" default="0.38062"/>
    <xacro:arg name="left_arm_mount_r" default="0.0"/>
    <xacro:arg name="left_arm_mount_p" default="0.0"/>
    <xacro:arg name="left_arm_mount_yaw" default="3.14159"/>

    <xacro:arg name="arm_base_yaw_limit_lower" default="-3.14"/>
    <xacro:arg name="arm_base_yaw_limit_upper" default="3.14"/>
    <xacro:arg name="arm_base_yaw_effort" default="50"/>
    <xacro:arg name="arm_base_yaw_velocity" default="50.0"/>
  
    <!-- Right Arm Mount -->
    <xacro:arg name="right_arm_mount_x" default="0.12"/>
    <xacro:arg name="right_arm_mount_y" default="-0.25"/>
    <xacro:arg name="right_arm_mount_z" default="0.38062"/>
    <xacro:arg name="right_arm_mount_r" default="0.0"/>
    <xacro:arg name="right_arm_mount_p" default="0.0"/>
    <xacro:arg name="right_arm_mount_yaw" default="3.14159"/>

    <!-- ================= IMPORTS ================= -->
    <xacro:include filename="$(find summit_xl_description)/robots/summit_xls.urdf.xacro"/>
    <xacro:include filename="$(find mm_description)/urdf/arm/arm.urdf.xacro"/>
    <!-- <xacro:include filename="$(find mm_description)/urdf/base/mecanum_vehicle.urdf.xacro"/> -->

    <!-- ================= 1. MOBILE BASE ================= -->
    <!-- <xacro:mecanum_vehicle prefix="$(arg prefix)"/> -->
    <xacro:summit_xl prefix="$(arg prefix)" publish_bf="true" hq="$(arg hq)"/>

    <!-- ================= 2. LEFT ARM ================= -->
    <joint name="$(arg prefix)left_arm_mount_joint" type="revolute">
        <parent link="$(arg prefix)base_link_platform"/>
        <child link="$(arg prefix)left_arm_root_link"/>
        <origin xyz="$(arg left_arm_mount_x) $(arg left_arm_mount_y) $(arg left_arm_mount_z)" 
                rpy="$(arg left_arm_mount_r) $(arg left_arm_mount_p) $(arg left_arm_mount_yaw)"/>
        <axis xyz="0 0 1"/>
        <limit lower="$(arg arm_base_yaw_limit_lower)" 
            upper="$(arg arm_base_yaw_limit_upper)" 
            effort="$(arg arm_base_yaw_effort)" 
            velocity="$(arg arm_base_yaw_velocity)"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>
    <xacro:arm prefix="$(arg prefix)left_" use_gazebo="$(arg use_gazebo)"/>

    <!-- ================= 3. RIGHT ARM ================= -->
    <joint name="$(arg prefix)right_arm_mount_joint" type="revolute">
        <parent link="$(arg prefix)base_link_platform"/>
        <child link="$(arg prefix)right_arm_root_link"/>
        <origin xyz="$(arg right_arm_mount_x) $(arg right_arm_mount_y) $(arg right_arm_mount_z)" 
                rpy="$(arg right_arm_mount_r) $(arg right_arm_mount_p) $(arg right_arm_mount_yaw)"/>
        <axis xyz="0 0 1"/>
        <limit lower="$(arg arm_base_yaw_limit_lower)" 
            upper="$(arg arm_base_yaw_limit_upper)" 
            effort="$(arg arm_base_yaw_effort)" 
            velocity="$(arg arm_base_yaw_velocity)"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>
    <xacro:arm prefix="$(arg prefix)right_" use_gazebo="$(arg use_gazebo)"/>

    <!-- ================= 4. MERGED ROS2_CONTROL ================= -->
    <xacro:if value="$(arg use_gazebo)">
        
        <!-- Gazebo plugin -->
        <gazebo>
        <plugin filename="gz_ros2_control-system" 
                name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find mm_control)/config/obotx_dual_arm_controllers.yaml</parameters>
            <ros>
                <remapping>/mecanum_drive_controller/reference:=/cmd_vel</remapping>
                <remapping>/mecanum_drive_controller/odom:=/odom</remapping>
            </ros>
        </plugin>
        </gazebo>

        <!-- Hardware definition -->
        <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>

        <!-- ===== MOBILE BASE WHEELS ===== -->
        <joint name="$(arg prefix)front_left_wheel_joint">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="$(arg prefix)front_right_wheel_joint">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="$(arg prefix)rear_left_wheel_joint">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="$(arg prefix)rear_right_wheel_joint">
            <command_interface name="velocity">
                <param name="min">-1</param>
                <param name="max">1</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="$(arg prefix)left_joint_slider_right_hinge" mimic="true">
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <!-- ===== LEFT ARM JOINTS ===== -->
        <joint name="$(arg prefix)left_arm_mount_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)left_joint_slider_left_slide">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)left_joint_slider_left_hinge">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)left_joint_telescopic_slide">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)left_joint_hinge_telescopic_hand">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)left_joint_slider_right_slide">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <!-- ===== RIGHT ARM JOINTS ===== -->
        <joint name="$(arg prefix)right_arm_mount_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)right_joint_slider_left_slide">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)right_joint_slider_left_hinge">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)right_joint_telescopic_slide">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)right_joint_hinge_telescopic_hand">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)right_joint_slider_right_slide">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="$(arg prefix)right_joint_slider_right_hinge" mimic="true">
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
            <state_interface name="effort"/>
        </joint>

        <!-- ===== DG4F GRIPPER JOINTS (Prefixed) ===== -->
        <joint name="$(arg prefix)left_j_dg_1_1">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)left_j_dg_1_2">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">1.5</param>
            </state_interface>
            <state_interface name="velocity" />
            <state_interface name="effort" />
        </joint>

        <joint name="$(arg prefix)left_j_dg_1_3">
            <command_interface name="position">
                <param name="min_position">-3.14</param>
                <param name="max_position">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_position">0.0</param>
